message: "If you use fastNLTK in your research, please cite it as below."
title: "fastNLTK: Drop-in Rust-accelerated replacement for NLTK"
authors:
  - family-names: Ferguson
    given-names: Wyatt
    orcid: "https://orcid.org/0009-0008-1975-4583"
year: 2025
